cc_library(
    name = "sdl2",
    hdrs = glob(["include/*.h"]),
    includes = ["include"],
    visibility = ["//visibility:public"],
    linkopts = select({
        "@platforms//os:windows": [],
        "@platforms//os:linux": ["-lSDL2"],
        "@platforms//os:macos": ["-lSDL2"],
    }),
    deps = select({
        "@platforms//os:windows": [":sdl2_win"],
        "//conditions:default": [],
    }),
)

# Windows: link against vendored import library
cc_import(
    name = "sdl2_win",
    interface_library = "lib/x64/SDL2.lib",
    shared_library = "lib/x64/SDL2.dll",
)
