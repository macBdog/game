cc_library(
    name = "lua",
    hdrs = glob(["include/*.h"]),
    includes = ["include"],
    visibility = ["//visibility:public"],
    linkopts = select({
        "@platforms//os:windows": [],
        "@platforms//os:linux": ["-llua5.2", "-lm"],
        "@platforms//os:macos": ["-llua", "-lm"],
    }),
    deps = select({
        "@platforms//os:windows": [":lua_win"],
        "//conditions:default": [],
    }),
)

# Windows: link against vendored import library
cc_import(
    name = "lua_win",
    interface_library = "lua52.lib",
    shared_library = "lua52.dll",
)
