{
    "version": "2.0.0",
    "options": {
        "shell": {
            "executable": "C:\\Program Files\\Git\\bin\\bash.exe",
            "args": ["-l", "-c"]
        }
    },
    "tasks": [
        {
            "label": "bazel-build-debug",
            "type": "shell",
            "command": "bazelisk build //:game --config=dbg",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc", "$msCompile"]
        },
        {
            "label": "bazel-build-release",
            "type": "shell",
            "command": "bazelisk build //:game --config=opt",
            "group": "build",
            "problemMatcher": ["$gcc", "$msCompile"]
        },
        {
            "label": "bazel-build-datapack",
            "type": "shell",
            "command": "bazelisk build //:game --config=datapack",
            "group": "build",
            "problemMatcher": ["$gcc", "$msCompile"]
        },
        {
            "label": "refresh-compile-commands",
            "type": "shell",
            "command": "bazelisk run //:refresh_compile_commands",
            "group": "build",
            "problemMatcher": []
        }
    ]
}
